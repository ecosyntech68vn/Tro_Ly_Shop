# ============================================================
# AI Thực Chiến · Bot Sepay · Cấu hình môi trường
# ============================================================
# Copy file này thành .env (KHÔNG commit .env lên Git)
# Trên Railway/Render: nhập từng biến trong UI "Environment Variables"

# --- Telegram ---
# Lấy từ BotFather sau khi /revoke token cũ (token cũ ĐÃ LỘ — phải revoke)
BOT_TOKEN=PASTE_NEW_BOT_TOKEN_HERE

# Chat ID admin: 558789316 (Tạ Quang Thuận @ThuanFX)
ADMIN_CHAT_ID=558789316

# --- Sepay ---
# Đăng ký tại sepay.vn → Cài đặt → API & Webhook → Tạo API Key
SEPAY_API_KEY=PASTE_SEPAY_API_KEY

# --- Ngân hàng MB Bank (Sepay có API trực tiếp) ---
BANK_ACCOUNT=3100181888868
BANK_NAME=MB Bank
BANK_OWNER=TA QUANG THUAN

# --- URL công khai sau khi deploy ---
# Railway sẽ cấp dạng: https://your-project.up.railway.app
BASE_URL=https://your-project.up.railway.app

# --- AI Agent — API Keys (chọn 1 trong 3 tuỳ gói khách mua) ---
# Gemini (dùng cho gói Basic): https://aistudio.google.com/apikey
GEMINI_API_KEY=PASTE_GEMINI_API_KEY
# Claude (dùng cho gói Pro): https://console.anthropic.com/
CLAUDE_API_KEY=PASTE_CLAUDE_API_KEY
# OpenAI GPT-4 (dùng cho gói Business): https://platform.openai.com/api-keys
OPENAI_API_KEY=PASTE_OPENAI_API_KEY

# --- Local dev (tùy chọn) ---
PORT=8000
DB_PATH=bot.db
